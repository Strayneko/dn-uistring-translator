package com.strayneko.rubysword;

import com.strayneko.rubysword.item.ModItems;
import net.fabricmc.api.ModInitializer;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

public class Rubysword implements ModInitializer {
	public static final String MOD_ID = "rubysword";

	public static final Logger LOGGER = LoggerFactory.getLogger(MOD_ID);

	@Override
	public void onInitialize() {
		ModItems.initialize();
		LOGGER.info("Ruby Sword mod initialized!");
	}
}